{
  "name": "oierdb-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "turbo run @oierdb/backend#dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:check": "turbo run lint:check",
    "check-types": "turbo run check-types",
    "postinstall": "husky install",
    "fmt": "prettier --write ."
  },
  "devDependencies": {
    "husky": "^8.0.2",
    "lint-staged": "^13.1.0",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.3.0"
  },
  "packageManager": "yarn@1.22.22",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css,less}": [
      "prettier --write",
      "git add"
    ]
  }
}
