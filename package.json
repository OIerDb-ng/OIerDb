{
  "name": "oierdb-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "install:generator": "python3 -m venv generator/.venv && generator/.venv/bin/pip install -r generator/requirements.txt",
    "generate": "generator/.venv/bin/python ./generator/main.py",
    "build:frontend": "turbo run @oierdb/frontend#build",
    "build:backend": "turbo run @oierdb/backend#build",
    "dev:frontend": "turbo run @oierdb/frontend#dev",
    "dev:backend": "turbo run @oierdb/backend#dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:check": "turbo run lint:check",
    "check-types": "turbo run check-types",
    "postinstall": "husky install",
    "fmt": "prettier --write ."
  },
  "devDependencies": {
    "husky": "^8.0.2",
    "lint-staged": "^13.1.0",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3"
  },
  "packageManager": "yarn@4.10.3",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css,less,scss}": [
      "prettier --write",
      "git add"
    ]
  }
}
